# Required authentication keys
KEPAPI_API_KEY=replace-me
KEPAPI_ADMIN_API_KEY=replace-me-admin

# Database connection
KEPAPI_DB_HOST=127.0.0.1
KEPAPI_DB_PORT=3306
KEPAPI_DB_USER=readonly_user
KEPAPI_DB_PASS=replace-me
KEPAPI_DB_CHARSET=utf8mb4

